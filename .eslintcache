t-Apps\\portfolio\\src\\index.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\NavBar.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\LandingPage.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Services.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Experience.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Footer.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Navbar.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Projects.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\SectionHeader.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Service.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Project.js",["93"],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\TimeLine.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Button.js",["94"],"import styles from \"./../Styles/Button.module.css\";\r\nexport function Button(props) {\r\n  return (\r\n    <div className={styles.button}>\r\n      <a href={props.link} target=\"_blank\">\r\n        {props.value}\r\n      </a>\r\n    </div>\r\n  );\r\n}\r\n","C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\GetInTouch.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Articles.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\socialMedia.js",["95","96","97","98","99"],"import styles from \"./../Styles/social_media.module.css\";\r\nexport function SocialMedia() {\r\n  return (\r\n    <div className={styles.wrapper}>\r\n      <a\r\n        className=\"fa fa-linkedin-square\"\r\n        style={{ color: \"#007bb5\" }}\r\n        href=\"https://www.linkedin.com/in/werdien-jihed/\"\r\n      ></a>\r\n      <a\r\n        className=\"fa fa-github-square\"\r\n        style={{ color: \"#211f1f\" }}\r\n        href=\"https://github.com/WerdienJihed\"\r\n      ></a>\r\n      <a\r\n        className=\"fa fa-facebook-square\"\r\n        style={{ color: \"#4267b2\" }}\r\n        href=\"https://www.facebook.com/werdien.jihed\"\r\n      ></a>\r\n      <a\r\n        className=\"fab fa-instagram-square\"\r\n        style={{ color: \"#e4405f\" }}\r\n        href=\"https://www.instagram.com/werdien_jihed/\"\r\n      ></a>\r\n      <a\r\n        className=\"fa fa-twitter-square\"\r\n        style={{ color: \"#1da1f2\" }}\r\n        href=\"https://twitter.com/werdien_jihed\"\r\n      ></a>\r\n    </div>\r\n  );\r\n}\r\n","C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\ContactMe.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\CustomPieChart.js",["100","101"],"import { PieChart, Pie, Sector, Cell } from \"recharts\";\r\nimport React, { PureComponent } from \"react\";\r\n\r\nconst RADIAN = Math.PI / 180;\r\n\r\nconst renderCustomizedLabel = ({\r\n  cx,\r\n  cy,\r\n  midAngle,\r\n  innerRadius,\r\n  outerRadius,\r\n  name,\r\n}) => {\r\n  const radius = innerRadius + (outerRadius - innerRadius) * 2.5;\r\n  const x = cx + radius * Math.cos(-midAngle * RADIAN);\r\n  const y = cy + radius * Math.sin(-midAngle * RADIAN);\r\n\r\n  return (\r\n    <text\r\n      x={x}\r\n      y={y}\r\n      fill=\"#EFD148\"\r\n      textAnchor={x > cx ? \"start\" : \"end\"}\r\n      dominantBaseline=\"central\"\r\n    >\r\n      {`${name}`}\r\n    </text>\r\n  );\r\n};\r\n\r\nexport default class CustomPieChart extends PureComponent {\r\n  constructor(props) {\r\n    super(props);\r\n  }\r\n\r\n  static jsfiddleUrl = \"https://jsfiddle.net/alidingling/w6wsrc52/\";\r\n\r\n  render() {\r\n    return (\r\n      <PieChart width={400} height={400}>\r\n        <Pie\r\n          data={this.props.coreData}\r\n          dataKey=\"value\"\r\n          nameKey=\"name\"\r\n          cx={200}\r\n          cy={200}\r\n          fill=\"#8884d8\"\r\n          outerRadius={60}\r\n          stroke=\"#1f2537\"\r\n        />\r\n        <Pie\r\n          data={this.props.shellData}\r\n          dataKey=\"value\"\r\n          nameKey=\"name\"\r\n          cx={200}\r\n          cy={200}\r\n          fill=\"#8884d8\"\r\n          innerRadius={70}\r\n          outerRadius={90}\r\n          label={renderCustomizedLabel}\r\n          stroke=\"#1f2537\"\r\n          {...this.props.shellData.map((entry, index) => (\r\n            <Cell key={`cell-${index}`} fill={\"color\"} />\r\n          ))}\r\n        />\r\n      </PieChart>\r\n    );\r\n  }\r\n}\r\n","C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Skills.js",[],"C:\\jihed\\Projects\\React-Apps\\portfolio\\src\\Components\\Home.js",[],{"ruleId":"102","replacedBy":"103"},{"ruleId":"104","replacedBy":"105"},{"ruleId":"106","severity":1,"message":"107","line":7,"column":7,"nodeType":"108","endLine":7,"endColumn":32},{"ruleId":"109","severity":1,"message":"110","line":5,"column":28,"nodeType":"111","endLine":5,"endColumn":43},{"ruleId":"112","severity":1,"message":"113","line":5,"column":7,"nodeType":"108","endLine":9,"endColumn":8},{"ruleId":"112","severity":1,"message":"113","line":10,"column":7,"nodeType":"108","endLine":14,"endColumn":8},{"ruleId":"112","severity":1,"message":"113","line":15,"column":7,"nodeType":"108","endLine":19,"endColumn":8},{"ruleId":"112","severity":1,"message":"113","line":20,"column":7,"nodeType":"108","endLine":24,"endColumn":8},{"ruleId":"112","severity":1,"message":"113","line":25,"column":7,"nodeType":"108","endLine":29,"endColumn":8},{"ruleId":"114","severity":1,"message":"115","line":1,"column":25,"nodeType":"116","messageId":"117","endLine":1,"endColumn":31},{"ruleId":"118","severity":1,"message":"119","line":32,"column":3,"nodeType":"120","messageId":"121","endLine":34,"endColumn":4},"no-native-reassign",["122"],"no-negated-in-lhs",["123"],"jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","react/jsx-no-target-blank","Us